# 基础配置
port: 7890
socks-port: 7891
redir-port: 7892
mixed-port: 7893
allow-lan: true
bind-address: "*"
mode: rule
log-level: warning
ipv6: false
find-process-mode: 'off'
external-controller: '127.0.0.1:9090'

# 性能优化
unified-delay: true
tcp-concurrent: true
global-client-fingerprint: chrome
keep-alive-idle: 600
keep-alive-interval: 15
disable-keep-alive: false

# 嗅探配置
sniffer:
  enable: false
  sniff:
    HTTP:
      ports: []
      override-destination: true
    TLS:
      ports: [443, 8443]
    QUIC:
      ports: [443, 8443]

# TUN 模式（按需启用）
tun:
  enable: true
  stack: mixed
  dns-hijack: ["any:53", "tcp://any:53"]
  auto-route: true
  auto-redirect: true
  auto-detect-interface: true

# 配置持久化
profile:
  store-selected: true
  store-fake-ip: false  

# [DNS设置]
dns:
  enable: true
  prefer-h3: true
  listen: 0.0.0.0:1053
  ipv6: false
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  fake-ip-filter:
    - "*"
    - +.lan
  default-nameserver:
    - 223.5.5.5
    - 119.29.29.29
  nameserver:
    - https://223.5.5.5/dns-query
    - https://119.29.29.29/dns-query

proxies:

# [策略组]
proxy-groups:
  - { name: "策略模式", type: select, proxies: [] }
  - { name: "推特服务", type: select, proxies: ["策略模式","优选模式"] }
  - { name: "飞机服务", type: select, proxies: ["策略模式","优选模式"] }
  - { name: "游戏服务", type: select, proxies: ["策略模式","DIRECT"] }
  - { name: "智能服务", type: select, proxies: ["策略模式","优选模式"] }
  - { name: "国际服务", type: select, proxies: ["策略模式","优选模式"] }
  - { name: "优选模式", type: url-test, lazy: true, url: http://www.gstatic.com/generate_204, interval: 900, proxies: [] }

# [本地规则]
rules:
  - RULE-SET,规则修正,DIRECT
  - RULE-SET,广告拦截,REJECT
  - RULE-SET,推特服务,推特服务
  - RULE-SET,飞机服务,飞机服务
  - RULE-SET,游戏服务,游戏服务
  - RULE-SET,智能服务,智能服务
  - RULE-SET,国际服务,国际服务
  - RULE-SET,国内服务,DIRECT
  - RULE-SET,局域网络,DIRECT
  - GEOIP, CN, DIRECT
  - MATCH,策略模式

# [远程规则]
rule-providers:
